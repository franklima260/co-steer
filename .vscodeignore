# Dependencies are bundled into dist/extension.js by esbuild, so node_modules is not shipped
node_modules/**

# Source and build intermediates (the extension ships the bundled dist/extension.js)
src/**
out/**
.vscode-test/**
test-fixtures/**

# Tooling / config not needed at runtime
esbuild.js
tsconfig.json
.github/**
.claude/**
.gitignore
.vscodeignore
*.vsix
**/*.map
**/*.ts

# Repo docs that don't belong in the published package
Testing_Standards.md
Telemetry_Standards.md
package-lock.json

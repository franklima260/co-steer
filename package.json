{
  "name": "co-steer",
  "displayName": "Co-Steer",
  "description": "Universal Artifact Review and Co-Steering",
  "version": "0.0.1",
  "publisher": "frank",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "co-steer.iterate",
        "title": "Iterate with Agent",
        "icon": "$(play)"
      },
      {
        "command": "co-steer.approve",
        "title": "Approve Artifact",
        "icon": "$(check)"
      },
      {
        "command": "co-steer.diff",
        "title": "Diff vs Target",
        "icon": "$(diff)"
      },
      {
        "command": "co-steer.addComment",
        "title": "Add Comment",
        "icon": "$(comment-add)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "co-steer.diff",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        },
        {
          "command": "co-steer.iterate",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        },
        {
          "command": "co-steer.approve",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "co-steer.addComment",
          "group": "navigation",
          "when": "commentThreadIsEmpty"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "co-steer-sidebar",
          "title": "Co-Steer",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "co-steer-sidebar": [
        {
          "id": "co-steer-artifacts",
          "name": "Artifacts"
        }
      ]
    },
    "configuration": {
      "title": "Co-Steer",
      "properties": {
        "co-steer.agentCommand": {
          "type": "string",
          "default": "",
          "markdownDescription": "Executable to run when iterating on an artifact (e.g. `claude`, `ollama`, or a wrapper script). The artifact file path is appended as the final argument. Leave empty to use the built-in mock (no agent is launched)."
        },
        "co-steer.agentArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional arguments passed to `#co-steer.agentCommand#` before the artifact file path."
        },
        "co-steer.promptPrefix": {
          "type": "string",
          "default": "Execute the following approved plan:",
          "markdownDescription": "Text prepended to an approved Markdown artifact when handing it off to the agent via \"Run as prompt\"."
        }
      }
    }
  },
  "activationEvents": [
    "onView:co-steer-artifacts"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "compile-tests": "tsc -p .",
    "watch-tests": "tsc -p . -w",
    "test": "npm run compile-tests && node ./out/test/runTest.js",
    "vsix": "vsce package --allow-missing-repository -o co-steer.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.6",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5",
    "npm-run-all": "^4.1.5",
    "@vscode/test-electron": "^2.4.0",
    "mocha": "^10.4.0",
    "glob": "^10.4.1",
    "@vscode/vsce": "^3.2.0"
  }
}

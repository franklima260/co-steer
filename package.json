{
  "name": "co-steer",
  "displayName": "Co-Steer",
  "description": "Universal Artifact Review and Co-Steering",
  "version": "0.0.1",
  "publisher": "frank",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "co-steer.reviewFile",
        "title": "Review File",
        "category": "Co-Steer",
        "icon": "$(eye)"
      },
      {
        "command": "co-steer.iterate",
        "title": "Iterate with Agent",
        "category": "Co-Steer",
        "icon": "$(play)"
      },
      {
        "command": "co-steer.approve",
        "title": "Approve Artifact",
        "category": "Co-Steer",
        "icon": "$(check)"
      },
      {
        "command": "co-steer.diff",
        "title": "Diff vs Target",
        "category": "Co-Steer",
        "icon": "$(diff)"
      },
      {
        "command": "co-steer.addComment",
        "title": "Add Comment",
        "category": "Co-Steer",
        "icon": "$(comment-add)"
      },
      {
        "command": "co-steer.copyPrompt",
        "title": "Copy Agent Prompt",
        "category": "Co-Steer",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "co-steer.addComment",
          "when": "false"
        },
        {
          "command": "co-steer.iterate",
          "when": "false"
        },
        {
          "command": "co-steer.approve",
          "when": "false"
        },
        {
          "command": "co-steer.diff",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "co-steer.reviewFile",
          "when": "view == co-steer-artifacts",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "co-steer.reviewFile",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "co-steer.reviewFile",
          "when": "!explorerResourceIsFolder",
          "group": "co-steer"
        }
      ],
      "view/item/context": [
        {
          "command": "co-steer.copyPrompt",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        },
        {
          "command": "co-steer.diff",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        },
        {
          "command": "co-steer.iterate",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        },
        {
          "command": "co-steer.approve",
          "when": "view == co-steer-artifacts",
          "group": "inline"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "co-steer.addComment",
          "group": "navigation",
          "when": "commentThreadIsEmpty"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "co-steer-sidebar",
          "title": "Co-Steer",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "co-steer-sidebar": [
        {
          "id": "co-steer-artifacts",
          "name": "Artifacts"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "co-steer-artifacts",
        "contents": "No artifacts are in review yet.\n\nOpen a file you want an AI agent to help with, then start a review.\n[Review a File](command:co-steer.reviewFile)\n\nHighlight lines in the review view and add comments; run Iterate to have your agent apply them."
      }
    ],
    "configuration": {
      "title": "Co-Steer",
      "properties": {
        "co-steer.agentCommand": {
          "type": "string",
          "default": "",
          "markdownDescription": "Executable to run when iterating on an artifact (e.g. `claude`, `ollama`, or a wrapper script). The artifact file path is appended as the final argument. Leave empty to use the built-in mock (no agent is launched)."
        },
        "co-steer.agentArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional arguments passed to `#co-steer.agentCommand#` before the artifact file path."
        },
        "co-steer.promptPrefix": {
          "type": "string",
          "default": "Execute the following approved plan:",
          "markdownDescription": "Text prepended to an approved Markdown artifact when handing it off to the agent via \"Run as prompt\"."
        },
        "co-steer.customCommentSyntaxes": {
          "type": "object",
          "default": {},
          "markdownDescription": "A dictionary mapping VS Code language IDs or file extensions to custom comment syntaxes (e.g. `{\"json\": \"//\", \"html\": [\"<!--\", \"-->\"]}`)."
        }
      }
    }
  },
  "activationEvents": [
    "onView:co-steer-artifacts",
    "onCommand:co-steer.reviewFile"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "compile-tests": "tsc -p .",
    "watch-tests": "tsc -p . -w",
    "test": "npm run compile-tests && node ./out/test/runTest.js",
    "vsix": "vsce package --allow-missing-repository -o co-steer.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.6",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5",
    "npm-run-all": "^4.1.5",
    "@vscode/test-electron": "^2.4.0",
    "mocha": "^10.4.0",
    "glob": "^10.4.1",
    "@vscode/vsce": "^3.2.0",
    "@types/markdown-it": "^14.1.1"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
